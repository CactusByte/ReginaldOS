# Required
ANTHROPIC_API_KEY=sk-ant-...

# Model (default: claude-opus-4-6)
MODEL=claude-opus-4-6

# Telegram (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_FROM=username1,username2

IMESSAGE_ALLOW_FROM=+15555551234,user@example.com 

# Server
PORT=18080

# Data directory (sessions + memory.db)
DATA_DIR=./data
