# =============================================================================
# SECURITY: Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is already listed in .gitignore.
# Rotate any key immediately if it is ever exposed in version control,
# logs, screenshots, or shared output.
# =============================================================================

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Model (default: claude-opus-4-6)
MODEL=claude-opus-4-6

# Port for the web UI
PORT=18080

# Data directory (sessions + memory.db)
DATA_DIR=./data

# Projects directory (per-session Astro sites)
PROJECTS_DIR=./data/projects

# Skills directory (scanned for SKILL.md subfolders)
SKILLS_DIR=./skills

# Cron job store
CRON_FILE=./data/cron/jobs.json

# -----------------------------------------------------------------------------
# Telegram (optional — leave empty to disable)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Comma-separated list of Telegram usernames allowed to message the bot
TELEGRAM_ALLOW_FROM=username1,username2

# -----------------------------------------------------------------------------
# iMessage (macOS only — requires Full Disk Access for the terminal)
# -----------------------------------------------------------------------------
# Comma-separated phone numbers and/or Apple IDs allowed to trigger the agent
IMESSAGE_ALLOW_FROM=+15555551234,user@example.com
# Path to the Messages SQLite database (default shown below)
IMESSAGE_CHAT_DB=/Users/YOUR_USERNAME/Library/Messages/chat.db
# How often to poll the database in milliseconds (default: 3000)
IMESSAGE_POLL_MS=3000

# -----------------------------------------------------------------------------
# Web search — Tavily (optional)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-...

# -----------------------------------------------------------------------------
# Image generation — OpenAI (optional)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...
IMAGE_MODEL=gpt-image-1

# -----------------------------------------------------------------------------
# Solana / Pump.fun (optional — required only if using the pumpfun tool)
# WARNING: SOLANA_PRIVATE_KEY gives full control of the wallet.
# Never share, log, or expose this value.
# -----------------------------------------------------------------------------
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# X / Twitter OAuth2 (optional — required only if using the X skill)
# See skills/x/.env.example for setup instructions.
# -----------------------------------------------------------------------------
X_BEARER_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH2_USER_TOKEN=
X_OAUTH2_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# MCP servers (optional) — JSON array of server configs
# Each entry is either:
#   {"type":"stdio","name":"...","command":"...","args":[...]}
#   {"type":"sse",  "name":"...","url":"http://..."}
#
# Uncomment and edit the servers you want. The value must be valid JSON on one line.
#
# Filesystem — read/write files in allowed directories (replace /Users/you with your actual home dir)
# MCP_SERVERS=[{"type":"stdio","name":"filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/Users/you"]}]
#
# Chrome DevTools — connect to a running Chrome with --remote-debugging-port=9222
# MCP_SERVERS=[{"type":"stdio","name":"chrome","command":"npx","args":["chrome-devtools-mcp"]}]
#
# GitHub — issues, PRs, repos (requires a personal access token)
# MCP_SERVERS=[{"type":"stdio","name":"github","command":"npx","args":["-y","@modelcontextprotocol/server-github"],"env":{"GITHUB_PERSONAL_ACCESS_TOKEN":"ghp_..."}}]
#
# Git — requires Python/uvx: uvx mcp-server-git --repository /path/to/repo
# MCP_SERVERS=[{"type":"stdio","name":"git","command":"uvx","args":["mcp-server-git","--repository","."]}]
#
# Multiple servers at once (replace /Users/you):
MCP_SERVERS=[{"type":"stdio","name":"filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/Users/you"]},{"type":"stdio","name":"chrome","command":"npx","args":["chrome-devtools-mcp"]}]
